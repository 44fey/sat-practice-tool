{
  "name": "sat-practice-tool",
  "version": "1.1.1",
  "private": true,
  "main": "electron-main.cjs",
  "scripts": {
    "scrape": "node scrape.mjs",
    "serve": "node serve.mjs",
    "smoke": "node smoke.mjs",
    "electron": "node run-electron.cjs",
    "icon": "node build/make-icon.cjs",
    "build:exe": "node run-electron-builder.cjs --win"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.fnaamani7.sat-practice-tool",
    "productName": "SAT Practice Tool",
    "asar": true,
    "files": [
      "electron-main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "viewer",
        "to": "viewer"
      },
      {
        "from": "data",
        "to": "data"
      },
      {
        "from": "desmos-offline-main",
        "to": "desmos-offline-main"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "signAndEditExecutable": false,
      "signtoolOptions": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SAT Practice Tool",
      "menuCategory": false,
      "artifactName": "SAT-Practice-Tool-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "SAT-Practice-Tool-Portable-${version}.exe"
    },
    "directories": {
      "output": "dist",
      "buildResources": "build"
    }
  }
}
