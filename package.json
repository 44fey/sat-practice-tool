{
  "name": "sat-practice-tool",
  "version": "1.0.0",
  "private": true,
  "main": "electron-main.cjs",
  "scripts": {
    "scrape": "node scrape.mjs",
    "serve": "node serve.mjs",
    "smoke": "node smoke.mjs",
    "electron": "node run-electron.cjs",
    "build:exe": "node run-electron-builder.cjs --win portable"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "com.fnaamani7.sat-practice-tool",
    "productName": "SAT Practice Tool",
    "asar": true,
    "files": [
      "electron-main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "viewer",
        "to": "viewer"
      },
      {
        "from": "data",
        "to": "data"
      },
      {
        "from": "desmos-offline-main",
        "to": "desmos-offline-main"
      }
    ],
    "win": {
      "target": "portable",
      "artifactName": "SAT-Practice-Tool.exe",
      "signAndEditExecutable": false,
      "signtoolOptions": null
    },
    "portable": {
      "artifactName": "SAT-Practice-Tool.exe"
    },
    "directories": {
      "output": "dist"
    }
  }
}
